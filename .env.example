# ─── MCP Gateway Configuration ─────────────────────────────────────────────
# Copy to .env and customize

# Gateway transport: stdio, sse, or streaming
# For LAN access, use streaming or sse
GATEWAY_TRANSPORT=streaming

# Port the gateway listens on inside the container
GATEWAY_PORT=8811

# Comma-separated list of MCP servers to enable from the Docker MCP Catalog
# Common servers: fetch, duckduckgo, filesystem, github-official, postgres
GATEWAY_SERVERS=fetch,duckduckgo

# Memory per MCP server container (default 2Gb)
GATEWAY_MEMORY=2Gb

# CPUs per MCP server container (default 1)
GATEWAY_CPUS=1

# Log tool calls (true/false)
GATEWAY_LOG_CALLS=true

# Verbose logging (true/false)
GATEWAY_VERBOSE=false

# Verify image signatures (true/false)
GATEWAY_VERIFY_SIGNATURES=false

# Block network access for tools (true/false)
GATEWAY_BLOCK_NETWORK=false

# Path to local catalog yaml (absolute or relative to ~/.docker/mcp/catalogs/)
# Leave empty to use the default Docker MCP Catalog
GATEWAY_CATALOG=

# Path to local config yaml (absolute or relative to ~/.docker/mcp/)
GATEWAY_CONFIG=
